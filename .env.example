# Telnyx
TELNYX_API_KEY=KEY_xxxxxxxxxxxxx
TELNYX_PUBLIC_KEY=xxxxxxxx          # Mission Control -> Keys & Credentials -> Public Key
VERIFY_SIGNATURES=false             # set true in production to reject spoofed webhooks

# Public URL where this app is reachable (Cloudflare Tunnel hostname, or ngrok in dev).
# Telnyx posts the menu here, and every <action>/<Record> URL is built from it.
BASE_URL=https://ivr.yourdomain.com

# Who each menu option rings. Comma-separated; each entry is a SIP agent
# (sip:user@sip.telnyx.com) or a PSTN number (+14155551234). Multiple = ring all
# at once, first to answer wins. Empty = that option goes straight to voicemail.
SALES_AGENTS=sip:agent1@sip.telnyx.com,sip:agent2@sip.telnyx.com
SUPPORT_AGENTS=sip:agent1@sip.telnyx.com
BILLING_AGENTS=+14155550333
OPERATOR_AGENTS=+14155550000
DIAL_TIMEOUT=20                     # seconds to ring each stage before failing over

# Auto-forward backups: if the agents above don't answer (e.g. SIP softphone
# offline), ring these PSTN numbers next, then voicemail. SIP -> cell -> voicemail.
SALES_FALLBACK=+14155550111
SUPPORT_FALLBACK=
BILLING_FALLBACK=
OPERATOR_FALLBACK=
AFTER_HOURS_FALLBACK=

# Voicemail (TeXML <Record>) when nobody answers.
ENABLE_VOICEMAIL=true
VOICEMAIL_MAX_SECONDS=120

# Recording + legal disclosure. ANNOUNCE_RECORDING plays "this call may be recorded
# for quality and monitoring" at the start of every call (edit wording in
# texml/menu.xml.j2). Required for monitoring/QA recording in many places. Turn on
# RECORD_CALLS to also record the live agent conversation (stored on Telnyx).
ANNOUNCE_RECORDING=true
RECORD_CALLS=false

# Optional: pre-recorded menu greeting (MP3/WAV). Avoids per-call TTS cost.
# MENU_AUDIO_URL=https://your-cdn/greeting.mp3

# Caller matching: numbers are matched against data/contacts.csv (instant, no API).
# Refresh it from HubSpot:  python scripts/sync_hubspot.py   (needs HUBSPOT_TOKEN)
# or drop in a CSV from any source with header: phone,name,company,tier
# HUBSPOT_TOKEN=pat-xxxxxxxxxxxxx
# HUBSPOT_LIVE_FALLBACK=false       # if a number isn't in the CSV, also try the HubSpot API

# Business hours come from data/hours.csv + data/holidays.csv (editable, per-day
# HH:MM). ENFORCE_BUSINESS_HOURS is the master switch; the BUSINESS_* vars below
# are only a fallback when hours.csv is absent.
# ENFORCE_BUSINESS_HOURS=true
# BUSINESS_TIMEZONE=America/New_York
# AFTER_HOURS_AGENTS=sip:oncall@sip.telnyx.com
# BUSINESS_OPEN_HOUR=9              # fallback only (no hours.csv)
# BUSINESS_CLOSE_HOUR=17
# BUSINESS_DAYS=0-4                 # Mon=0 .. Sun=6

# Public holidays are computed automatically (correct floating/observed dates
# every year) — no yearly editing. data/holidays.csv is only for company-specific
# closures. Set AUTO_HOLIDAYS=false to use only the CSV.
# AUTO_HOLIDAYS=true
# HOLIDAY_COUNTRY=US
# HOLIDAY_SUBDIV=CA                 # optional: state/province-specific holidays

# Optional: Cloudflare Tunnel token (only for `docker compose --profile tunnel up`).
# TUNNEL_TOKEN=eyJ...

# Optional: outbound heartbeat (dead-man's switch). The app pings this URL on an
# interval; if the app dies, pings stop and your monitor alerts. Create a free
# check at healthchecks.io and paste its ping URL here.
# HEARTBEAT_URL=https://hc-ping.com/your-uuid
# HEARTBEAT_INTERVAL_SECONDS=60

DEBUG=true
