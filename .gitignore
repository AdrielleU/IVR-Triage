# Environment variables
.env
.env.local

# Caller data — may contain customer PII; keep out of version control.
# (data/hours.csv and data/holidays.csv ARE tracked on purpose.)
data/contacts.csv
# Per-company routing (your internal agent numbers). Copy from companies.example.csv.
data/companies.csv
# Agent roster (your internal SIP/PSTN/assistant destinations). Copy from routing.example.csv.
data/routing.csv

# Call/voicemail recordings + transcripts (customer PII) — keep the folder, not its contents.
recordings/*
!recordings/.gitkeep

# Pre-recorded prompt clips — host-mounted like data/ and texml/, so the audio
# itself isn't version-controlled. Keep the folder + its README. Un-ignore
# specific clips (e.g. !audio/menu.mp3) if you'd rather commit them.
audio/*
!audio/.gitkeep
!audio/README.md

