{#- Said when a call wraps up (agent answered and the call ended, or after a
    voicemail). Variables: voice, audio_url. -#}
<?xml version="1.0" encoding="UTF-8"?>
<Response>
{%- if audio_url %}
  <Play>{{ audio_url }}</Play>
{%- else %}
  <Say voice="{{ voice }}">Thanks for calling. Goodbye.</Say>
{%- endif %}
  <Hangup/>
</Response>
