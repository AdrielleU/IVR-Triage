{#- Main IVR menu. Edit the wording / options freely; the next call uses it.
    Available variables: caller_name (or None), voice, base_url, menu_audio_url. -#}
<?xml version="1.0" encoding="UTF-8"?>
<Response>
{%- if announce_recording %}
  <Say voice="{{ voice }}">This call may be recorded for quality and monitoring purposes.</Say>
{%- endif %}
  <Gather numDigits="1" timeout="7" action="{{ base_url }}/texml/handle-input" method="POST">
{%- if menu_audio_url %}
    <Play>{{ menu_audio_url }}</Play>
{%- else %}
    <Say voice="{{ voice }}">{% if caller_name %}Welcome back, {{ caller_name }}. {% else %}Thanks for calling. {% endif %}For sales, press 1. For technical support, press 2. For billing or account questions, press 3. To speak with an operator, press 0.</Say>
{%- endif %}
  </Gather>
  <Say voice="{{ voice }}">We did not receive a selection. Goodbye.</Say>
  <Hangup/>
</Response>
