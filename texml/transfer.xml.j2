{#- Rings one stage's destinations. If none answer within dial_timeout, the
    action callback (/texml/after-dial) fails over to the next stage or voicemail.
    from_display is the SIP caller-ID name the agent's phone shows ("Sales - Jane
    Doe"); the caller's own number stays as the callerId for callback.
    Variables: department, destinations[], dial_timeout, from_display, action_url, voice. -#}
<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Say voice="{{ voice }}">Connecting you to {{ department }}. Please hold.</Say>
  <Dial timeout="{{ dial_timeout }}"{% if from_display %} fromDisplayName="{{ from_display }}"{% endif %} action="{{ action_url }}" method="POST"{% if record_calls %} record="record-from-answer" recordingStatusCallback="{{ recording_callback }}"{% endif %}>
{%- include "_dial.xml.j2" %}
  </Dial>
</Response>
