{#- A menu option was chosen but no agents are configured for it. Goes to
    voicemail so the caller isn't dropped. Variables: department, dept_key,
    max_seconds, voice, base_url. -#}
<?xml version="1.0" encoding="UTF-8"?>
<Response>
  <Say voice="{{ voice }}">Sorry, {{ department }} is not staffed right now. Please leave a message after the beep.</Say>
  <Record maxLength="{{ max_seconds }}" finishOnKey="#" playBeep="true"
          action="{{ base_url }}/texml/voicemail-done?dept={{ dept_key }}" method="POST"
          recordingStatusCallback="{{ base_url }}/texml/recording?dept={{ dept_key }}" />
  <Say voice="{{ voice }}">We did not receive a message. Goodbye.</Say>
  <Hangup/>
</Response>
