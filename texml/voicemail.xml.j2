{#- Voicemail / busy prompt. With configured options it offers "for <label>, press
    <digit>" and the no-press timeout Redirects to /vm-option (which repeats up to
    busy_prompt_repeats, then plays the closing message). With NO options it plays the
    prompt and records a message directly (Telnyx posts it to /texml/recording).
    Variables: department, dept_key, max_seconds, voice, base_url, audio_url,
    options (list of {digit,label}), option_action. -#}
<?xml version="1.0" encoding="UTF-8"?>
<Response>
{%- if option_action %}
  <Gather numDigits="1" timeout="6" action="{{ option_action }}" method="POST">
  {%- if audio_url %}
    <Play>{{ audio_url }}</Play>
  {%- else %}
    <Say voice="{{ voice }}">Sorry, no one is available{% if department and department != 'us' %} in {{ department }}{% endif %} right now. {% for o in options %}For {{ o.label }}, press {{ o.digit }}. {% endfor %}</Say>
  {%- endif %}
  </Gather>
  {#- No key pressed: bounce back so the prompt repeats (bounded) or the call closes. -#}
  <Redirect>{{ option_action }}</Redirect>
{%- else %}
  {%- if audio_url %}
  <Play>{{ audio_url }}</Play>
  {%- else %}
  <Say voice="{{ voice }}">Sorry, no one is available{% if department and department != 'us' %} in {{ department }}{% endif %} right now. Please leave a message after the beep, then press pound or hang up.</Say>
  {%- endif %}
  <Record maxLength="{{ max_seconds }}" finishOnKey="#" playBeep="true"
          action="{{ base_url }}/texml/voicemail-done?dept={{ dept_key }}&amp;co={{ co }}" method="POST"
          recordingStatusCallback="{{ base_url }}/texml/recording?dept={{ dept_key }}&amp;co={{ co }}" />
  <Say voice="{{ voice }}">We did not receive a message. Goodbye.</Say>
  <Hangup/>
{%- endif %}
</Response>
